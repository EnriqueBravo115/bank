Authorization: Bearer {{tokenAdmin}}

### GET financial - detail (CUSTOMER_BASIC)
GET {{baseUrl}}/get-detail/1
Authorization: Bearer {{tokenBasic}}

### GET financial - by occupation (ADMIN)
GET {{baseUrl}}/get-by-occupation/EMPLOYEE
Authorization: Bearer {{tokenAdmin}}

### GET financial - by income source (ADMIN)
GET {{baseUrl}}/get-by-income-source/SALARY
Authorization: Bearer {{tokenAdmin}}

### GET financial - by marital status (ADMIN)
GET {{baseUrl}}/get-by-marital-status/SINGLE
Authorization: Bearer {{tokenAdmin}}

### GET financial - by income range (ADMIN)
GET {{baseUrl}}/get-by-income-range?min=1&max=30000
Authorization: Bearer {{tokenAdmin}}

### GET financial - all detailed (ADMIN)
GET {{baseUrl}}/get-all-detailed
Authorization: Bearer {{tokenAdmin}}

### GET financial - active (ADMIN)
GET {{baseUrl}}/get-active
Authorization: Bearer {{tokenAdmin}}

### GET financial - exists (CUSTOMER_BASIC)
